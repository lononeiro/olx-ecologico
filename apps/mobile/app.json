{
  "expo": {
    "name": "ECOnecta",
    "slug": "econecta-mobile",
    "scheme": "econecta",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiBaseUrl": "https://olx-ecologico.vercel.app/"
    },
    "android": {
      "package": "com.econecta.mobile"
    },
    "ios": {
      "bundleIdentifier": "com.econecta.mobile"
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}
