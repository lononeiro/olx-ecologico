@startuml CP-09-avaliar-coleta
title CP-09 - Avaliar Coleta (robustez) [NOVO]
left to right direction
actor "Cidadao" as ator
boundary "Form de Avaliacao" as b1
boundary "POST /api/avaliacoes" as b2
control "avaliacaoCreateSchema" as c1
control "criarAvaliacao()\n(dono + concluida + unica)" as c2
control "notificarAvaliacaoRecebida()" as c3
entity "Coleta" as e1
entity "Avaliacao" as e2
entity "Notificacao" as e3

ator -- b1
b1 -- b2
b2 -- c1
c1 -- c2
c2 -- e1
c2 -- e2
c2 -- c3
c3 -- e3
@enduml
