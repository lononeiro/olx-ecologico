@startuml CP-05-negociar-pre-aceite
title CP-05 - Negociar (chat pre-aceite) (robustez) [NOVO]
left to right direction
actor "Empresa" as a1
actor "Cidadao" as a2
boundary "Chat de negociacao" as b1
boundary "POST /api/conversas-solicitacao/[id]/mensagens" as b2
control "buscarConversaAutorizada()" as c1
control "enviarMensagemConversaSolicitacao()" as c2
control "notificarNovaMensagem()" as c3
entity "ConversaSolicitacao" as e1
entity "MensagemPreAceite" as e2
entity "Notificacao" as e3

a1 -- b1
a2 -- b1
b1 -- b2
b2 -- c1
c1 -- e1
c1 -- c2
c2 -- e2
c2 -- c3
c3 -- e3
@enduml
