@startuml CP-08-chat-coleta
title CP-08 - Conversar na Coleta (robustez)
left to right direction
actor "Cidadao / Empresa" as ator
boundary "Chat da Coleta" as b1
boundary "POST /api/mensagens/[coletaId]" as b2
control "verificarAcessoColeta()" as c1
control "enviarMensagem()" as c2
control "notificarNovaMensagem()" as c3
entity "Coleta" as e1
entity "Mensagem" as e2
entity "Notificacao" as e3

ator -- b1
b1 -- b2
b2 -- c1
c1 -- e1
c1 -- c2
c2 -- e2
c2 -- c3
c3 -- e3
@enduml
