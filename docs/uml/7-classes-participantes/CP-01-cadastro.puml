@startuml CP-01-cadastro
title CP-01 - Cadastro de Usuario/Empresa (robustez)
left to right direction
actor "Visitante" as ator
boundary "Tela /register" as b1
boundary "POST /api/auth/register" as b2
control "registerSchema (Zod)" as c1
control "registerUsuario()" as c2
entity "User" as e1
entity "Company" as e2
entity "Role" as e3

ator -- b1
b1 -- b2
b2 -- c1
c1 -- c2
c2 -- e1
c2 -- e2
c2 -- e3
@enduml
