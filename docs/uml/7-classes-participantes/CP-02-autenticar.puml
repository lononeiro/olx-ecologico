@startuml CP-02-autenticar
title CP-02 - Autenticar (robustez)
left to right direction
actor "Usuario" as ator
boundary "Tela /login" as b1
boundary "NextAuth / mobile/login" as b2
control "loginSchema" as c1
control "authenticateUserByCredentials\n(bcrypt.compare)" as c2
control "emite sessao JWT / tokens" as c3
entity "User" as e1
entity "Role" as e2

ator -- b1
b1 -- b2
b2 -- c1
c1 -- c2
c2 -- e1
e1 -- e2
c2 -- c3
@enduml
