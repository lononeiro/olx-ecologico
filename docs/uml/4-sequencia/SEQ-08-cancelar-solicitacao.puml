@startuml SEQ-08-cancelar-solicitacao
title SEQ-08 - Cancelar Solicitacao (pelo proprio cidadao)
actor Cidadao
participant "PATCH /api/solicitacoes/[id]" as EP
participant "solicitacao.service\ncancelarSolicitacao" as SVC
database PostgreSQL as DB

Cidadao -> EP : PATCH {action: "cancelar"}
EP -> SVC : cancelarSolicitacao(id, userId)
group Transacao
  SVC -> DB : findFirst(id, userId) include coleta
  alt nao encontrada / sem permissao
    SVC --> EP : throw
    EP --> Cidadao : 400
  else
    SVC -> SVC : status rejeitada/cancelada? -> erro
    SVC -> SVC : coleta em em_coleta/concluida? -> erro
    alt coleta em aceita/a_caminho
      SVC -> DB : update Coleta -> cancelada
    end
    SVC -> DB : update Solicitacao -> cancelada
    SVC --> EP : {solicitacao, coletaCancelada}
    EP --> Cidadao : 200
  end
end
@enduml
