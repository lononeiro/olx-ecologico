{
  "name": "recycling-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "expo": "54.0.35",
    "metro": "0.83.3",
    "metro-babel-transformer": "0.83.3",
    "metro-cache": "0.83.3",
    "metro-cache-key": "0.83.3",
    "metro-config": "0.83.3",
    "metro-core": "0.83.3",
    "metro-file-map": "0.83.3",
    "metro-minify-terser": "0.83.3",
    "metro-resolver": "0.83.3",
    "metro-runtime": "0.83.3",
    "metro-source-map": "0.83.3",
    "metro-symbolicate": "0.83.3",
    "metro-transform-plugins": "0.83.3",
    "metro-transform-worker": "0.83.3"
  },
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:mobile": "npm run dev -w apps/mobile",
    "dev:mobile:clear": "npm run dev -w apps/mobile -- --port 8082 --clear",
    "build": "prisma generate && next build",
    "build:web": "prisma generate && next build",
    "start": "next start",
    "start:mobile": "npm run start -w apps/mobile",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck:shared": "tsc -p packages/shared/tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "ts-node -P tsconfig.seed.json prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node -P tsconfig.seed.json prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "leaflet": "^1.9.4",
    "next": "^14.2.29",
    "next-auth": "^4.24.11",
    "next-cloudinary": "^6.17.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.32.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.14",
    "@types/react-dom": "^18.3.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.16",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
